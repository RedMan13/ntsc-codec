{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build",
            "command": "g++",
            "args": ["./main.cpp", "-g", "-o", "./dev"],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Builds the app"
        },
        {
            "label": "cleanup",
            "command": "node",
            "args": ["./fixup.js"],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "none",
                "isDefault": false
            },
            "detail": "Cleans up the test result"
        }
    ],
    "version": "2.0.0"
}